# Python cache
__pycache__/
*.py[cod]
*.egg-info/

# Virtualenvs / env
.venv/
venv/
.env

# IDE / editor / OS junk
.claude/
.pytest_cache/
.ipynb_checkpoints/
.DS_Store
Thumbs.db

# Source datasets (not redistributed)
/millionsongsubset/

# Generated workspace outputs -- large, regenerable
/msd_deezer_workspace/audio/
/msd_deezer_workspace/cache/
/msd_deezer_workspace/logs/
/msd_deezer_workspace/features/raw/
/msd_deezer_workspace/features/feature_vectors.csv
/msd_deezer_workspace/sample_runs/
/msd_deezer_workspace/data/*.tmp
/msd_deezer_workspace/data/*.pending.csv
# Deezer download working state -- msd_deezer_catalog.csv is the committed seed,
# the working CSV is regenerated from it on every fresh run.
/msd_deezer_workspace/data/msd_deezer_matches.csv
/calendar/

# Per-song NPZ dump (tens of GB) -- the fused + per-model CSVs beside it stay tracked
/msd_deezer_workspace/pretrained_embeddings/raw/

# Parallel-extraction shard intermediates -- never commit
/msd_deezer_workspace/pretrained_embeddings_musicnn/
/msd_deezer_workspace/pretrained_embeddings_mert/
/msd_deezer_workspace/pretrained_embeddings_encodecmae/
/msd_deezer_workspace/pretrained_embeddings_logs/

# HuggingFace / torch model caches
hf_cache/
.cache/
